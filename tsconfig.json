{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "types": [
      "nativewind/types"
    ]
  },
  "scopes": {
    "@expo/metro-runtime": [
      "./node_modules/@expo/metro-runtime"
    ]
  },
  "scripts": {
    //"dev": true,
    "start": true,
    "dev": "run",
    "build": true,
    "test": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "./index.ts",
    "nativewind-env.d.ts"
  ]
}